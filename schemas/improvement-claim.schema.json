{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/improvement-claim.schema.json",
  "title": "ImprovementClaim",
  "description": "The falsifiable statement attached to a distilled skill or routine update (ADR 0025): the criterion it targets, the baseline friction it was distilled from, and the expected violation ceiling going forward. Violation counts are computed mechanically from the friction ledger; a human closes the claim (D5). A refuted claim reopens the fix via a superseding claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "created_on",
    "target_skill",
    "criterion_id",
    "creator_slug",
    "baseline",
    "expectation",
    "evidence_event_ids",
    "status"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^claim_[a-zA-Z0-9_-]+$"
    },
    "created_on": {
      "type": "string",
      "format": "date"
    },
    "target_skill": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "criterion_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.]*$"
    },
    "creator_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_description",
        "violation_count"
      ],
      "properties": {
        "window_description": {
          "type": "string",
          "minLength": 1
        },
        "violation_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "window_description",
        "max_violations"
      ],
      "properties": {
        "window_description": {
          "type": "string",
          "minLength": 1
        },
        "max_violations": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "evidence_event_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^event_[a-zA-Z0-9_-]+$"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "confirmed",
        "refuted",
        "withdrawn"
      ]
    },
    "closed_on": {
      "type": "string",
      "format": "date"
    },
    "closed_by": {
      "type": "string",
      "enum": [
        "user"
      ]
    },
    "supersedes_claim_id": {
      "type": "string",
      "pattern": "^claim_[a-zA-Z0-9_-]+$"
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
