{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/micro-journey-video-plan.schema.json",
  "title": "MicroJourneyVideoPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "micro_journey_video_plan_id",
    "creator_profile_id",
    "idea_promotion_id",
    "applied_social_template_id",
    "default_video_envelope",
    "hook",
    "retain",
    "payoff",
    "cta_or_loop",
    "intended_emotion",
    "shots",
    "continuity_requirements"
  ],
  "properties": {
    "micro_journey_video_plan_id": {
      "type": "string",
      "pattern": "^mjvp_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "applied_social_template_id": {
      "type": "string",
      "pattern": "^applied_template_[a-zA-Z0-9_-]+$"
    },
    "default_video_envelope": {
      "type": "string",
      "const": "universal_short_form_vertical"
    },
    "hook": {
      "type": "string",
      "minLength": 1
    },
    "retain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["setup", "escalation"],
      "properties": {
        "setup": {
          "type": "string",
          "minLength": 1
        },
        "escalation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "payoff": {
      "type": "string",
      "minLength": 1
    },
    "cta_or_loop": {
      "type": "string",
      "minLength": 1
    },
    "intended_emotion": {
      "type": "string",
      "minLength": 1
    },
    "shots": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shot_id",
          "time_range",
          "visual_action",
          "camera_or_motion",
          "emotional_job"
        ],
        "properties": {
          "shot_id": {
            "type": "string",
            "pattern": "^shot_[a-zA-Z0-9_-]+$"
          },
          "time_range": {
            "type": "string",
            "minLength": 1
          },
          "visual_action": {
            "type": "string",
            "minLength": 1
          },
          "camera_or_motion": {
            "type": "string",
            "minLength": 1
          },
          "emotional_job": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "continuity_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "idea_promotion_id": {
      "type": "string",
      "pattern": "^idea_promotion_[a-zA-Z0-9_-]+$"
    }
  }
}
