{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/social-post-format.schema.json",
  "title": "SocialPostFormat",
  "type": "object",
  "additionalProperties": false,
  "required": ["social_post_format_id", "name", "artifact_kind", "best_for", "planning_notes", "v1_status"],
  "properties": {
    "social_post_format_id": { "type": "string", "pattern": "^format_[a-zA-Z0-9_-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "artifact_kind": { "type": "string", "enum": ["video", "image_sequence", "single_image", "visual_sequence"] },
    "best_for": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "planning_notes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "v1_status": { "type": "string", "enum": ["implemented", "shortlisted", "deferred"] }
  }
}

