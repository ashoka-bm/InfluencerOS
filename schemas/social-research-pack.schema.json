{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/social-research-pack.schema.json",
  "title": "SocialResearchPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["social_research_pack_id", "creator_profile_id", "researched_on", "scope", "sources", "observed_patterns", "creator_fit_notes"],
  "properties": {
    "social_research_pack_id": { "type": "string", "pattern": "^research_[a-zA-Z0-9_-]+$" },
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "researched_on": { "type": "string", "format": "date" },
    "scope": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "evidence_note"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "evidence_note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "observed_patterns": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "creator_fit_notes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}

