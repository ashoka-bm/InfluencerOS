{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/research-search-terms.schema.json",
  "title": "ResearchSearchTerms",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "research_search_terms_id",
    "creator_profile_id",
    "updated_on",
    "items"
  ],
  "properties": {
    "research_search_terms_id": {
      "type": "string",
      "pattern": "^research_search_terms_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "search_term_id": {
            "type": "string",
            "pattern": "^search_term_[a-zA-Z0-9_-]+$"
          },
          "term": {
            "type": "string",
            "minLength": 1
          },
          "platform": {
            "type": "string",
            "enum": [
              "x",
              "instagram",
              "tiktok",
              "substack",
              "medium",
              "reddit",
              "facebook",
              "linkedin",
              "youtube",
              "public_web"
            ]
          },
          "creator_profile_id": {
            "type": "string",
            "pattern": "^creator_[a-zA-Z0-9_-]+$"
          },
          "usefulness_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "active",
              "flagged_for_removal",
              "retired"
            ]
          },
          "added_on": {
            "type": "string",
            "format": "date"
          },
          "updated_on": {
            "type": "string",
            "format": "date"
          },
          "last_evaluated_on": {
            "type": "string",
            "format": "date"
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "search_term_id",
          "term",
          "platform",
          "creator_profile_id",
          "usefulness_score",
          "status",
          "added_on",
          "updated_on",
          "last_evaluated_on",
          "rationale"
        ]
      }
    }
  }
}
