{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/creator-profile.schema.json",
  "title": "CreatorProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["creator_profile_id", "display_name", "niche", "target_audience", "persona", "visual_identity", "content_boundaries", "goals"],
  "properties": {
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "display_name": { "type": "string", "minLength": 1 },
    "niche": { "type": "string", "minLength": 1 },
    "target_audience": { "type": "string", "minLength": 1 },
    "persona": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "visual_identity": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "content_boundaries": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "goals": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}

