{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/research-sources.schema.json",
  "title": "ResearchSources",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "research_sources_id",
    "creator_profile_id",
    "updated_on",
    "items"
  ],
  "properties": {
    "research_sources_id": {
      "type": "string",
      "pattern": "^research_sources_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source_intel_id": {
            "type": "string",
            "pattern": "^source_intel_[a-zA-Z0-9_-]+$"
          },
          "url": {
            "type": "string",
            "pattern": "^https?://"
          },
          "platform": {
            "type": "string",
            "enum": [
              "x",
              "instagram",
              "tiktok",
              "substack",
              "medium",
              "reddit",
              "facebook",
              "linkedin",
              "youtube"
            ]
          },
          "creator_profile_id": {
            "type": "string",
            "pattern": "^creator_[a-zA-Z0-9_-]+$"
          },
          "usefulness_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "active",
              "flagged_for_removal",
              "retired"
            ]
          },
          "added_on": {
            "type": "string",
            "format": "date"
          },
          "updated_on": {
            "type": "string",
            "format": "date"
          },
          "last_evaluated_on": {
            "type": "string",
            "format": "date"
          },
          "yield_stats": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "checked_count",
              "promoted_to_evidence_count",
              "background_use_count",
              "low_yield_count",
              "usefulness_basis"
            ],
            "properties": {
              "checked_count": {
                "type": "integer",
                "minimum": 0
              },
              "promoted_to_evidence_count": {
                "type": "integer",
                "minimum": 0
              },
              "background_use_count": {
                "type": "integer",
                "minimum": 0
              },
              "low_yield_count": {
                "type": "integer",
                "minimum": 0
              },
              "last_checked_on": {
                "type": "string",
                "format": "date"
              },
              "last_useful_on": {
                "type": "string",
                "format": "date"
              },
              "usefulness_basis": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "source_intel_id",
          "url",
          "creator_profile_id",
          "usefulness_score",
          "status",
          "added_on",
          "updated_on",
          "last_evaluated_on",
          "yield_stats",
          "rationale"
        ]
      }
    }
  }
}
