{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/creator-content-schedule.schema.json",
  "title": "CreatorContentSchedule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "creator_content_schedule_id",
    "creator_profile_id",
    "creator_slug",
    "content_strategy_id",
    "updated_on",
    "research_basis",
    "cadence_expectations",
    "content_goals",
    "calendar_slots",
    "drift_checks"
  ],
  "properties": {
    "creator_content_schedule_id": {
      "type": "string",
      "pattern": "^content_schedule_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "creator_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "content_strategy_id": {
      "type": "string",
      "pattern": "^content_strategy_[a-zA-Z0-9_-]+$"
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "research_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "research_run_ids"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "strategy_scaffold",
            "research_informed"
          ]
        },
        "research_run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^research_run_[a-zA-Z0-9_-]+$"
          }
        }
      }
    },
    "cadence_expectations": {
      "type": "string",
      "minLength": 1
    },
    "content_goals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "goal_id": {
            "type": "string",
            "pattern": "^goal_[a-zA-Z0-9_-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "target_mix": {
            "type": "string",
            "minLength": 1
          },
          "preferred_platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "x",
                "instagram",
                "tiktok",
                "substack",
                "medium",
                "reddit",
                "facebook",
                "linkedin",
                "youtube"
              ]
            }
          },
          "preferred_formats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "format_short_form_video",
                "format_carousel",
                "format_single_image_post",
                "format_story_sequence",
                "format_article",
                "format_thread"
              ]
            }
          }
        },
        "required": [
          "goal_id",
          "name",
          "description",
          "target_mix",
          "preferred_platforms",
          "preferred_formats"
        ]
      },
      "minItems": 1
    },
    "calendar_slots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "slot_id": {
            "type": "string",
            "pattern": "^slot_[a-zA-Z0-9_-]+$"
          },
          "target_date": {
            "type": "string",
            "format": "date"
          },
          "date_flexibility": {
            "type": "string",
            "minLength": 1
          },
          "content_goal_id": {
            "type": "string",
            "pattern": "^goal_[a-zA-Z0-9_-]+$"
          },
          "research_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "research_run_ids"
            ],
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "unresearched",
                  "candidates_ready",
                  "selected",
                  "inherits_anchor"
                ]
              },
              "research_run_ids": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^research_run_[a-zA-Z0-9_-]+$"
                }
              },
              "selected_idea_queue_entry_id": {
                "type": "string",
                "pattern": "^idea_queue_entry_[a-zA-Z0-9_-]+$"
              },
              "anchor_slot_id": {
                "type": "string",
                "pattern": "^slot_[a-zA-Z0-9_-]+$"
              }
            }
          },
          "topic_cluster": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "reserved",
              "filled",
              "skipped"
            ]
          },
          "working_title": {
            "type": "string",
            "minLength": 1
          },
          "platform": {
            "type": "string",
            "enum": [
              "x",
              "instagram",
              "tiktok",
              "substack",
              "medium",
              "reddit",
              "facebook",
              "linkedin",
              "youtube"
            ]
          },
          "format_id": {
            "type": "string",
            "enum": [
              "format_short_form_video",
              "format_carousel",
              "format_single_image_post",
              "format_story_sequence",
              "format_article",
              "format_thread"
            ]
          },
          "format_label": {
            "type": "string",
            "minLength": 1
          },
          "theme": {
            "type": "string",
            "minLength": 1
          },
          "funnel_role": {
            "type": "string",
            "minLength": 1
          },
          "cta": {
            "type": "string",
            "minLength": 1
          },
          "production_note": {
            "type": "string",
            "minLength": 1
          },
          "week_label": {
            "type": "string",
            "minLength": 1
          },
          "conversion_asset_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^conversion_asset_[a-zA-Z0-9_-]+$"
            }
          },
          "conversion_use": {
            "type": "string",
            "minLength": 1
          },
          "content_campaign_id": {
            "type": "string",
            "pattern": "^campaign_[a-zA-Z0-9_-]+$"
          },
          "variant_id": {
            "type": "string",
            "pattern": "^variant_[a-zA-Z0-9_-]+$"
          }
        },
        "required": [
          "slot_id",
          "target_date",
          "date_flexibility",
          "content_goal_id",
          "research_state",
          "topic_cluster",
          "status"
        ]
      }
    },
    "drift_checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "under_served": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "over_served": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recent_repetition_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "under_served",
        "over_served",
        "recent_repetition_notes"
      ]
    },
    "blackout_dates": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "date"
      }
    },
    "active_campaigns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "time_sensitive_insertions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recently_published_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
