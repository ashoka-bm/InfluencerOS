{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/published-post-record.schema.json",
  "title": "PublishedPostRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["published_post_record_id", "output_package_id", "project_id", "creator_profile_id", "platform", "platform_account", "published_at", "publication_status", "public_url", "platform_post_id", "assets_used", "publication_method", "notes"],
  "properties": {
    "published_post_record_id": { "type": "string", "pattern": "^ppr_[a-zA-Z0-9_-]+$" },
    "output_package_id": { "type": "string", "pattern": "^output_package_[a-zA-Z0-9_-]+$" },
    "project_id": { "type": "string", "pattern": "^project_[a-zA-Z0-9_-]+$" },
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "platform": { "type": "string", "minLength": 1 },
    "platform_account": { "type": "string", "minLength": 1 },
    "published_at": { "type": "string", "minLength": 1 },
    "publication_status": { "type": "string", "enum": ["published", "scheduled", "failed", "deleted", "updated"] },
    "public_url": { "type": ["string", "null"] },
    "platform_post_id": { "type": ["string", "null"] },
    "assets_used": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title_used", "caption_or_description_path", "thumbnail_or_first_frame_asset_id", "primary_media_asset_ids"],
      "properties": {
        "title_used": { "type": "string", "minLength": 1 },
        "caption_or_description_path": { "type": "string", "minLength": 1 },
        "thumbnail_or_first_frame_asset_id": { "type": "string", "pattern": "^upload_asset_[a-zA-Z0-9_-]+$" },
        "primary_media_asset_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^upload_asset_[a-zA-Z0-9_-]+$" } }
      }
    },
    "publication_method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "actor", "scheduler_ref"],
      "properties": {
        "method": { "type": "string", "enum": ["manual_upload", "scheduled_upload", "api_upload", "unknown"] },
        "actor": { "type": "string", "minLength": 1 },
        "scheduler_ref": { "type": ["string", "null"] }
      }
    },
    "notes": { "type": "string", "minLength": 1 }
  }
}
