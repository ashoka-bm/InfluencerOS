{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/video-understanding-pack.schema.json",
  "title": "VideoUnderstandingPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["video_understanding_pack_id", "creator_profile_id", "researched_on", "research_question", "sources", "cross_video_patterns", "creator_fit_findings"],
  "properties": {
    "video_understanding_pack_id": { "type": "string", "pattern": "^video_research_[a-zA-Z0-9_-]+$" },
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "researched_on": { "type": "string", "format": "date" },
    "research_question": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "url_or_path", "title", "source_type", "analysis_method", "observations"],
        "properties": {
          "source_id": { "type": "string", "pattern": "^video_source_[a-zA-Z0-9_-]+$" },
          "url_or_path": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "enum": ["public_url", "local_file"] },
          "analysis_method": {
            "type": "object",
            "additionalProperties": false,
            "required": ["frames_sampled", "transcript_source", "focused_range"],
            "properties": {
              "frames_sampled": { "type": "string", "minLength": 1 },
              "transcript_source": { "type": "string", "enum": ["captions", "whisper", "none", "unknown"] },
              "focused_range": { "type": "string", "minLength": 1 }
            }
          },
          "observations": {
            "type": "object",
            "additionalProperties": false,
            "required": ["opening_hook", "first_frame_pattern", "visual_structure", "spoken_or_text_framing", "template_signals", "replicable_moves", "avoid_notes"],
            "properties": {
              "opening_hook": { "type": "string", "minLength": 1 },
              "first_frame_pattern": { "type": "string", "minLength": 1 },
              "visual_structure": { "type": "string", "minLength": 1 },
              "spoken_or_text_framing": { "type": "string", "minLength": 1 },
              "template_signals": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "pattern": "^template_[a-zA-Z0-9_-]+$" }
              },
              "replicable_moves": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "avoid_notes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            }
          }
        }
      }
    },
    "cross_video_patterns": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "creator_fit_findings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}

