{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/review-record.schema.json",
  "title": "ReviewRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_record_id",
    "project_id",
    "creator_profile_id",
    "review_role",
    "artifact_refs",
    "findings",
    "approval_status",
    "reviewer_execution",
    "created_at"
  ],
  "properties": {
    "review_record_id": {
      "type": "string",
      "pattern": "^review_[a-zA-Z0-9_-]+$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^project_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "concept_approval_id": {
      "type": "string",
      "pattern": "^concept_approval_[a-zA-Z0-9_-]+$"
    },
    "review_role": {
      "type": "string",
      "enum": ["hook_payoff", "creator_fit", "fact_check"]
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["area", "severity", "note"],
        "properties": {
          "area": {
            "type": "string",
            "enum": ["hook", "retain", "payoff", "cta", "general"]
          },
          "severity": {
            "type": "string",
            "enum": ["none", "low", "medium", "high", "blocking"]
          },
          "note": {
            "type": "string",
            "minLength": 1
          },
          "recommended_revision": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "approval_status": {
      "type": "string",
      "enum": ["approve", "revise", "block"]
    },
    "reviewer_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_mode", "source_skill"],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": ["bounded_sub_agent", "fallback_separated_pass"]
        },
        "source_skill": {
          "type": "string",
          "minLength": 1
        },
        "fallback_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "human_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waived_by", "waived_on", "reason"],
      "properties": {
        "waived_by": {
          "type": "string",
          "const": "user"
        },
        "waived_on": {
          "type": "string",
          "format": "date"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
