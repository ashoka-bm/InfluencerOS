{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/review-record.schema.json",
  "title": "ReviewRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_record_id",
    "creator_profile_id",
    "review_role",
    "artifact_refs",
    "findings",
    "approval_status",
    "reviewer_execution",
    "created_at"
  ],
  "properties": {
    "review_record_id": {
      "type": "string",
      "pattern": "^review_[a-zA-Z0-9_-]+$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^project_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "concept_approval_id": {
      "type": "string",
      "pattern": "^concept_approval_[a-zA-Z0-9_-]+$"
    },
    "review_role": {
      "type": "string",
      "enum": ["hook_payoff", "creator_fit", "fact_check", "setup", "strategy", "quarterly", "concept"]
    },
    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["area", "severity", "note"],
        "properties": {
          "area": {
            "type": "string",
            "enum": ["hook", "retain", "payoff", "cta", "general", "foundation", "positioning", "audience", "strategy", "evidence", "schedule", "visual_identity"]
          },
          "severity": {
            "type": "string",
            "enum": ["none", "low", "medium", "high", "blocking"]
          },
          "note": {
            "type": "string",
            "minLength": 1
          },
          "recommended_revision": {
            "type": "string",
            "minLength": 1
          },
          "research_demand": {
            "type": "string",
            "enum": ["new", "carried_forward"],
            "description": "machine-readable ADR 0046 state: a newly issued Research Demand or a prior unresolved demand carried into this review; only valid on ladder review roles"
          }
        }
      }
    },
    "approval_status": {
      "type": "string",
      "enum": ["approve", "revise", "block"]
    },
    "reviewer_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution_mode", "source_skill"],
      "properties": {
        "execution_mode": {
          "type": "string",
          "enum": ["bounded_sub_agent", "fallback_separated_pass"]
        },
        "source_skill": {
          "type": "string",
          "minLength": 1
        },
        "fallback_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "research_demand_loop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extra_research_round", "prior_review_record_id"],
      "properties": {
        "extra_research_round": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "prior_review_record_id": {
          "type": ["string", "null"],
          "pattern": "^review_[a-zA-Z0-9_-]+$"
        }
      }
    },
    "human_waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waived_by", "waived_on", "reason"],
      "properties": {
        "waived_by": {
          "type": "string",
          "const": "user"
        },
        "waived_on": {
          "type": "string",
          "format": "date"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "oneOf": [
    {
      "properties": {
        "review_role": { "enum": ["hook_payoff", "creator_fit", "fact_check"] }
      }
    },
    {
      "properties": {
        "review_role": { "const": "setup" },
        "artifact_refs": {
          "allOf": [
            { "contains": { "const": "creator-profile.json" } },
            { "contains": { "const": "brand_context/identity.md" } },
            { "contains": { "const": "brand_context/soul.md" } },
            { "contains": { "const": "brand_context/personal-brand.md" } },
            { "contains": { "const": "references/reference-library.json" } },
            { "contains": { "pattern": "^references/(character|brand)/[^/]+\\.(png|jpg|jpeg|webp)$" } },
            { "contains": { "const": "references/visual-continuity-plan.json" } }
          ]
        }
      }
    },
    {
      "properties": {
        "review_role": { "const": "strategy" },
        "artifact_refs": {
          "allOf": [
            { "contains": { "const": "creator-profile.json" } },
            { "contains": { "const": "content-strategy.json" } },
            { "contains": { "const": "content-schedule.json" } },
            { "contains": { "const": "research/findings.md" } },
            { "contains": { "pattern": "^research/runs/research_run_[a-zA-Z0-9_-]+/evidence\\.jsonl$" } }
          ]
        }
      },
      "required": ["research_demand_loop"],
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "research_demand_loop": {
                  "properties": {
                    "extra_research_round": { "const": 0 },
                    "prior_review_record_id": { "const": null }
                  }
                }
              }
            },
            {
              "properties": {
                "research_demand_loop": {
                  "properties": {
                    "extra_research_round": { "enum": [1, 2] },
                    "prior_review_record_id": {
                      "type": "string",
                      "pattern": "^review_[a-zA-Z0-9_-]+$"
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    },
    {
      "properties": {
        "review_role": { "enum": ["quarterly", "concept"] }
      }
    }
  ]
}
