{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/performance-summary.schema.json",
  "title": "PerformanceSummary",
  "type": "object",
  "additionalProperties": false,
  "required": ["performance_summary_id", "project_id", "creator_profile_id", "created_on", "evidence_refs", "stage_findings", "distilled_lessons", "semantic_lookup", "recommended_next_actions"],
  "properties": {
    "performance_summary_id": { "type": "string", "pattern": "^performance_summary_[a-zA-Z0-9_-]+$" },
    "project_id": { "type": "string", "pattern": "^project_[a-zA-Z0-9_-]+$" },
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "created_on": { "type": "string", "format": "date" },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_package_id", "published_post_record_ids", "analytics_snapshot_ids", "source_material_refs"],
      "properties": {
        "output_package_id": { "type": "string", "pattern": "^output_package_[a-zA-Z0-9_-]+$" },
        "published_post_record_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^ppr_[a-zA-Z0-9_-]+$" } },
        "analytics_snapshot_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^analytics_snapshot_[a-zA-Z0-9_-]+$" } },
        "source_material_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "stage_findings": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "result", "interpretation", "confidence"],
        "properties": {
          "stage": { "type": "string", "enum": ["packaging", "hook", "body_retention", "payoff", "cta"] },
          "result": { "type": "string", "minLength": 1 },
          "interpretation": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "distilled_lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lesson_id", "lesson", "applies_to", "evidence_strength"],
        "properties": {
          "lesson_id": { "type": "string", "pattern": "^lesson_[a-zA-Z0-9_-]+$" },
          "lesson": { "type": "string", "minLength": 1 },
          "applies_to": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "evidence_strength": { "type": "string", "enum": ["single_post_signal", "multi_post_pattern", "weak_signal"] }
        }
      }
    },
    "semantic_lookup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index_allowed", "summary_text"],
      "properties": {
        "index_allowed": { "type": "boolean" },
        "summary_text": { "type": "string", "minLength": 1 }
      }
    },
    "recommended_next_actions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
