{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/thread-plan.schema.json",
  "title": "ThreadPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "thread_plan_id",
    "creator_profile_id",
    "idea_promotion_id",
    "applied_social_template_id",
    "target_format_id",
    "platform_style",
    "opening_post",
    "throughline",
    "posts",
    "voice_and_style_constraints",
    "cta",
    "review_notes"
  ],
  "properties": {
    "thread_plan_id": {
      "type": "string",
      "pattern": "^thread_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "idea_promotion_id": {
      "type": "string",
      "pattern": "^idea_promotion_[a-zA-Z0-9_-]+$"
    },
    "applied_social_template_id": {
      "type": "string",
      "pattern": "^applied_template_[a-zA-Z0-9_-]+$"
    },
    "target_format_id": {
      "type": "string",
      "const": "format_thread"
    },
    "platform_style": {
      "type": "string",
      "minLength": 1
    },
    "opening_post": {
      "type": "string",
      "minLength": 1
    },
    "throughline": {
      "type": "string",
      "minLength": 1
    },
    "posts": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "post_id",
          "post_role",
          "copy",
          "evidence_to_use",
          "reader_job"
        ],
        "properties": {
          "post_id": {
            "type": "string",
            "pattern": "^post_[a-zA-Z0-9_-]+$"
          },
          "post_role": {
            "type": "string",
            "minLength": 1
          },
          "copy": {
            "type": "string",
            "minLength": 1
          },
          "evidence_to_use": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reader_job": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "voice_and_style_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cta": {
      "type": "string",
      "minLength": 1
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "format_subtype": {
      "type": "string",
      "enum": [
        "chain",
        "single_post"
      ]
    }
  }
}
