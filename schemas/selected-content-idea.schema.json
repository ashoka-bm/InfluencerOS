{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/selected-content-idea.schema.json",
  "title": "SelectedContentIdea",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_content_idea_id",
    "content_idea_set_id",
    "idea_id",
    "selected_by",
    "selection_note"
  ],
  "properties": {
    "selected_content_idea_id": {
      "type": "string",
      "pattern": "^selected_[a-zA-Z0-9_-]+$"
    },
    "content_idea_set_id": {
      "type": "string",
      "pattern": "^ideas_[a-zA-Z0-9_-]+$"
    },
    "idea_id": {
      "type": "string",
      "pattern": "^idea_[a-zA-Z0-9_-]+$"
    },
    "selected_by": {
      "type": "string",
      "enum": [
        "user"
      ]
    },
    "selection_note": {
      "type": "string",
      "minLength": 1
    }
  },
  "$comment": "Deprecated (ADR 0020): replaced by the IdeaQueue/IdeaPromotion research module. Kept only as a compatibility artifact; the intended pipeline no longer reads this record."
}
