{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/concept-approval.schema.json",
  "title": "ConceptApproval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "concept_approval_id",
    "campaign_concept_id",
    "creator_profile_id",
    "approved_by",
    "approved_on",
    "approval_status",
    "approved_platforms",
    "approved_formats",
    "max_offer_integration",
    "max_cta_intensity",
    "project_ids_created",
    "evidence_refs"
  ],
  "properties": {
    "concept_approval_id": {
      "type": "string",
      "pattern": "^concept_approval_[a-zA-Z0-9_-]+$"
    },
    "campaign_concept_id": {
      "type": "string",
      "pattern": "^campaign_concept_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "approved_by": {
      "type": "string",
      "enum": [
        "user"
      ]
    },
    "approved_on": {
      "type": "string",
      "format": "date"
    },
    "approval_status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "cancelled"
      ]
    },
    "approved_platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "x",
          "instagram",
          "tiktok",
          "substack",
          "medium",
          "reddit",
          "facebook",
          "linkedin",
          "youtube"
        ]
      },
      "minItems": 1
    },
    "approved_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "format_short_form_video",
          "format_carousel",
          "format_single_image_post",
          "format_story_sequence",
          "format_article",
          "format_thread"
        ]
      },
      "minItems": 1
    },
    "max_offer_integration": {
      "type": "string",
      "enum": [
        "absent",
        "embedded",
        "contextual",
        "central"
      ]
    },
    "max_cta_intensity": {
      "type": "string",
      "enum": [
        "none",
        "soft",
        "direct"
      ]
    },
    "project_ids_created": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^project_[a-zA-Z0-9_-]+$"
      },
      "minItems": 1
    },
    "schedule_slot_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^slot_[a-zA-Z0-9_-]+$"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "research_run_id": {
            "type": "string",
            "pattern": "^research_run_[a-zA-Z0-9_-]+$"
          },
          "evidence_id": {
            "type": "string",
            "pattern": "^evidence_[a-zA-Z0-9_-]+$"
          },
          "metric_snapshot_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^metric_snapshot_[a-zA-Z0-9_-]+$"
            }
          },
          "video_understanding_pack_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^video_research_[a-zA-Z0-9_-]+$"
            }
          }
        },
        "required": [
          "research_run_id",
          "evidence_id"
        ]
      }
    },
    "approval_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
