{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/project.schema.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "creator_profile_id", "project_slug", "created_on", "status", "content_unit_type", "source_refs", "project_paths", "target_formats", "learning_goal", "acceptance_criteria"],
  "properties": {
    "project_id": { "type": "string", "pattern": "^project_[a-zA-Z0-9_-]+$" },
    "creator_profile_id": { "type": "string", "pattern": "^creator_[a-zA-Z0-9_-]+$" },
    "project_slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "created_on": { "type": "string", "format": "date" },
    "status": { "type": "string", "enum": ["idea_selected", "planned", "packaged", "published", "analyzed", "archived"] },
    "content_unit_type": { "type": "string", "enum": ["short_form_video", "carousel", "single_image_post", "story_sequence", "multi_platform_package"] },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected_content_idea_id", "research_pack_ids", "reference_asset_ids"],
      "properties": {
        "selected_content_idea_id": { "type": "string", "pattern": "^selected_[a-zA-Z0-9_-]+$" },
        "research_pack_ids": { "type": "array", "items": { "type": "string", "pattern": "^(research|video_research)_[a-zA-Z0-9_-]+$" } },
        "reference_asset_ids": { "type": "array", "items": { "type": "string", "pattern": "^asset_[a-zA-Z0-9_-]+$" } }
      }
    },
    "project_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "idea", "plan", "output_package", "published", "analytics", "performance_summary"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "idea": { "type": "string", "const": "idea/" },
        "plan": { "type": "string", "const": "plan/" },
        "output_package": { "type": "string", "const": "output-package/" },
        "published": { "type": "string", "const": "published/" },
        "analytics": { "type": "string", "const": "analytics/" },
        "performance_summary": { "type": "string", "const": "performance-summary.md" }
      }
    },
    "target_formats": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^format_[a-zA-Z0-9_-]+$" } },
    "platform_targets": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "learning_goal": { "type": "string", "minLength": 1 },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "constraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "notes": { "type": "string", "minLength": 1 }
  }
}
