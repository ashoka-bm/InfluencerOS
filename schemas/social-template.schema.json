{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/social-template.schema.json",
  "title": "SocialTemplate",
  "type": "object",
  "additionalProperties": false,
  "required": ["social_template_id", "name", "compatible_format_ids", "best_for", "beat_sequence", "retention_or_clarity_job", "avoid_when"],
  "properties": {
    "social_template_id": { "type": "string", "pattern": "^template_[a-zA-Z0-9_-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "compatible_format_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^format_[a-zA-Z0-9_-]+$" }
    },
    "best_for": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "beat_sequence": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["beat_label", "beat_job", "beat_role"],
        "properties": {
          "beat_label": { "type": "string", "minLength": 1 },
          "beat_job": { "type": "string", "minLength": 1 },
          "beat_role": {
            "type": "string",
            "enum": ["hook", "retain", "payoff", "cta", "packaging"]
          },
          "hook_category": {
            "type": "string",
            "enum": [
              "identity_call_out",
              "pattern_interrupt",
              "contrarian",
              "result_first",
              "curiosity_gap",
              "direct_challenge",
              "confession",
              "timeliness",
              "problem_solution",
              "reveal_teaser",
              "bold_promise"
            ]
          }
        }
      }
    },
    "retention_or_clarity_job": { "type": "string", "minLength": 1 },
    "avoid_when": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}

