{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/content-idea-set.schema.json",
  "title": "ContentIdeaSet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "content_idea_set_id",
    "creator_profile_id",
    "social_research_pack_id",
    "video_understanding_pack_ids",
    "ideas"
  ],
  "properties": {
    "content_idea_set_id": {
      "type": "string",
      "pattern": "^ideas_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "social_research_pack_id": {
      "type": "string",
      "pattern": "^research_[a-zA-Z0-9_-]+$"
    },
    "video_understanding_pack_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^video_research_[a-zA-Z0-9_-]+$"
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idea_id",
          "title",
          "hook",
          "visual_premise",
          "audience_reason",
          "creator_fit",
          "target_emotion",
          "trend_evidence",
          "evidence_ref_ids",
          "novelty_angle",
          "production_complexity",
          "platform_travel_reason",
          "recommended_format_ids",
          "recommended_template_ids"
        ],
        "properties": {
          "idea_id": {
            "type": "string",
            "pattern": "^idea_[a-zA-Z0-9_-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "hook": {
            "type": "string",
            "minLength": 1
          },
          "visual_premise": {
            "type": "string",
            "minLength": 1
          },
          "audience_reason": {
            "type": "string",
            "minLength": 1
          },
          "creator_fit": {
            "type": "string",
            "minLength": 1
          },
          "target_emotion": {
            "type": "string",
            "minLength": 1
          },
          "trend_evidence": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(research|video_research)_[a-zA-Z0-9_-]+$"
            }
          },
          "novelty_angle": {
            "type": "string",
            "minLength": 1
          },
          "production_complexity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "platform_travel_reason": {
            "type": "string",
            "minLength": 1
          },
          "recommended_format_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^format_[a-zA-Z0-9_-]+$"
            }
          },
          "recommended_template_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^template_[a-zA-Z0-9_-]+$"
            }
          }
        }
      }
    }
  },
  "$comment": "Deprecated (ADR 0020): replaced by the IdeaQueue/IdeaPromotion research module. Kept only as a compatibility artifact; the intended pipeline no longer reads this record."
}
