{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/single-image-post-plan.schema.json",
  "title": "SingleImagePostPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "single_image_post_plan_id",
    "creator_profile_id",
    "idea_promotion_id",
    "applied_social_template_id",
    "target_format_id",
    "central_visual_idea",
    "composition",
    "avatar_or_scene_requirements",
    "text_overlay_policy",
    "generation_prompt"
  ],
  "properties": {
    "single_image_post_plan_id": {
      "type": "string",
      "pattern": "^single_image_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "applied_social_template_id": {
      "type": "string",
      "pattern": "^applied_template_[a-zA-Z0-9_-]+$"
    },
    "target_format_id": {
      "type": "string",
      "const": "format_single_image_post"
    },
    "central_visual_idea": {
      "type": "string",
      "minLength": 1
    },
    "composition": {
      "type": "string",
      "minLength": 1
    },
    "avatar_or_scene_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "text_overlay_policy": {
      "type": "string",
      "minLength": 1
    },
    "generation_prompt": {
      "type": "string",
      "minLength": 1
    },
    "idea_promotion_id": {
      "type": "string",
      "pattern": "^idea_promotion_[a-zA-Z0-9_-]+$"
    }
  }
}
