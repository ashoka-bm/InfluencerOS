{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/article-plan.schema.json",
  "title": "ArticlePlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "article_plan_id",
    "creator_profile_id",
    "idea_promotion_id",
    "applied_social_template_id",
    "target_format_id",
    "working_title",
    "deck",
    "thesis",
    "sections",
    "voice_and_style_constraints",
    "cta",
    "review_notes"
  ],
  "properties": {
    "article_plan_id": {
      "type": "string",
      "pattern": "^article_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "idea_promotion_id": {
      "type": "string",
      "pattern": "^idea_promotion_[a-zA-Z0-9_-]+$"
    },
    "applied_social_template_id": {
      "type": "string",
      "pattern": "^applied_template_[a-zA-Z0-9_-]+$"
    },
    "target_format_id": {
      "type": "string",
      "const": "format_article"
    },
    "working_title": {
      "type": "string",
      "minLength": 1
    },
    "deck": {
      "type": "string",
      "minLength": 1
    },
    "thesis": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "section_role",
          "headline",
          "key_points",
          "evidence_to_use",
          "reader_job"
        ],
        "properties": {
          "section_id": {
            "type": "string",
            "pattern": "^section_[a-zA-Z0-9_-]+$"
          },
          "section_role": {
            "type": "string",
            "minLength": 1
          },
          "headline": {
            "type": "string",
            "minLength": 1
          },
          "key_points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "evidence_to_use": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "reader_job": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "voice_and_style_constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cta": {
      "type": "string",
      "minLength": 1
    },
    "review_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "format_subtype": {
      "type": "string",
      "enum": [
        "essay",
        "reported_feature",
        "newsletter_dispatch"
      ]
    }
  }
}
