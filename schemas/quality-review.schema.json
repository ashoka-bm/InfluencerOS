{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/quality-review.schema.json",
  "title": "QualityReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quality_review_id",
    "project_id",
    "creator_profile_id",
    "scope_asset_ids",
    "checklist",
    "overall_verdict",
    "reviewed_at"
  ],
  "properties": {
    "quality_review_id": {
      "type": "string",
      "pattern": "^quality_review_[a-zA-Z0-9_-]+$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^project_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "scope_asset_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^gen_asset_[a-zA-Z0-9_-]+$"
      }
    },
    "checklist": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "result", "notes"],
        "properties": {
          "check": {
            "type": "string",
            "enum": [
              "identity_consistency",
              "continuity_with_plan",
              "technical_conformance",
              "creator_boundary_compliance"
            ]
          },
          "result": {
            "type": "string",
            "enum": ["pass", "fail", "not_applicable"]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "overall_verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "reviewer_notes": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
