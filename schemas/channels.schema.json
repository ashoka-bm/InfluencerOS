{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://influencer-os.local/schemas/channels.schema.json",
  "title": "Channels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "channels_id",
    "creator_profile_id",
    "creator_slug",
    "updated_on",
    "channels"
  ],
  "properties": {
    "channels_id": {
      "type": "string",
      "pattern": "^channels_[a-zA-Z0-9_-]+$"
    },
    "creator_profile_id": {
      "type": "string",
      "pattern": "^creator_[a-zA-Z0-9_-]+$"
    },
    "creator_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "channel_id",
          "platform",
          "intended_handle",
          "public_url",
          "account_status",
          "production_drafting_allowed",
          "publishing_export_blocked",
          "production_approved",
          "notes"
        ],
        "properties": {
          "channel_id": {
            "type": "string",
            "pattern": "^channel_[a-zA-Z0-9_-]+$"
          },
          "platform": {
            "type": "string",
            "enum": ["x", "instagram", "tiktok", "substack", "medium", "reddit", "facebook", "linkedin", "youtube"]
          },
          "intended_handle": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "public_url": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "account_status": {
            "type": "string",
            "enum": ["not_created", "created", "connected", "skipped"]
          },
          "production_drafting_allowed": { "type": "boolean" },
          "publishing_export_blocked": { "type": "boolean" },
          "production_approved": { "type": "boolean" },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
