# InfluencerOS research-acquisition connectors (ADR 0022)
#
# Copy to .env and fill in the keys you have. .env is gitignored — never commit
# real keys. A connector is active only when its key is present; with no key the
# run falls back to built-in public WebSearch/WebFetch. Key presence is standing
# approval for that connector's research-acquisition calls (ADR 0022).

# Reddit research via OpenAI Responses web_search (domain-locked to reddit.com).
# Returns threads with upvotes/comments -> ResearchEvidence + MetricSnapshot.
OPENAI_API_KEY=

# X/Twitter research via xAI x_search. Returns posts with engagement.
XAI_API_KEY=

# Firecrawl: render/scrape JS-heavy public pages (incl. rendered Reddit).
FIRECRAWL_API_KEY=

# Apify: public LinkedIn profile/post scraping.
APIFY_API_KEY=

# --- Guardrails (optional) ---
# Per-run cap on paid connector calls (default applied in code if unset).
INFLUENCER_OS_CONNECTOR_MAX_CALLS=
# Set to 1 to disable the entire paid connector tier regardless of keys.
INFLUENCER_OS_DISABLE_PAID_CONNECTORS=
